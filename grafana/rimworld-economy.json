          },
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_resource_stockpile{item_def=~\"Steel|ComponentIndustrial|ComponentSpacer|Plasteel\"}",
          "legendFormat": "{{item_label}}",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 216,
      "type": "timeseries",
      "title": "Medicine & Drugs",
      "description": "Medical supplies and drugs in stockpile.",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },

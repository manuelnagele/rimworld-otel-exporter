    {
      "id": 217,
      "type": "row",
      "title": "Food",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 218,
      "type": "timeseries",
      "title": "Food Days Remaining",
      "description": "Watch for downward trend — catch food crisis before it hits.",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "d",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#e898a8", "value": null },
              { "color": "#d4b896", "value": 3 },
              { "color": "#8ec4a8", "value": 7 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_food_days_remaining",
          "legendFormat": "Food Days",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 219,
      "type": "timeseries",
      "title": "Food Items by Type",
      "description": "Individual food item counts over time, stacked.",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 40,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" }
          },

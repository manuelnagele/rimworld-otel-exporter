{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "enable": true,
        "expr": "{service_name=\"rimworld-colony\"} | json | event_type=~\"incident\"",
        "hide": false,
        "iconColor": "#e898a8",
        "name": "Raids",
        "step": "60s",
        "titleFormat": "{{body}}",
        "tagKeys": "event_type"
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "enable": true,
        "expr": "{service_name=\"rimworld-colony\"} | json | event_type=\"death\"",
        "hide": false,
        "iconColor": "#c0392b",
        "name": "Deaths",
        "step": "60s",
        "titleFormat": "{{body}}",
        "tagKeys": "event_type"
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "enable": true,
        "expr": "{service_name=\"rimworld-colony\"} | json | event_type=\"mental_break\"",
        "hide": false,
        "iconColor": "#d4b896",
        "name": "Mental Breaks",
        "step": "60s",
        "titleFormat": "{{body}}",
        "tagKeys": "event_type"
      }
    ]
  },
  "description": "RimWorld combat and threats drilldown — threat budget, faction relations, combat state, and event log.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Colony Command Center",
      "tooltip": "Back to main dashboard",
      "type": "link",
      "url": "/d/rimworld-colony-v2"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["rimworld", "gaming", "homelab", "combat", "threats"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RimWorld — Combat & Threats",
  "uid": "rimworld-threats",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "pluginId": "prometheus",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "DS_LOKI",
        "label": "Loki",
        "type": "datasource",
        "pluginId": "loki",
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [

    {
      "id": 301,
      "type": "row",
      "title": "Threat Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 302,
      "type": "stat",
      "title": "Threat Points",
      "description": "Current storyteller threat budget. Higher = more dangerous raids.",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 300 },
              { "color": "#e898a8", "value": 800 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_storyteller_threat_points",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 303,
      "type": "stat",
      "title": "Hostile Pawns",
      "description": "Enemies currently on the map.",
      "gridPos": { "x": 3, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#e898a8", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_hostile_pawns_on_map",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 304,
      "type": "stat",
      "title": "Downed Colonists",
      "description": "Colonists currently downed in combat or injury.",
      "gridPos": { "x": 5, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#e898a8", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_downed_total",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 305,
      "type": "stat",
      "title": "Mental Breaks",
      "description": "Colonists currently in a mental break state.",
      "gridPos": { "x": 7, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 1 },
              { "color": "#e898a8", "value": 3 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_mental_state_active",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 306,
      "type": "stat",
      "title": "Drafted",
      "description": "Colonists currently drafted for combat.",
      "gridPos": { "x": 9, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_drafted_total",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 307,
      "type": "stat",
      "title": "Fire",
      "description": "Active fires on map.",
      "gridPos": { "x": 11, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#e898a8", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_fire_count",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 308,
      "type": "stat",
      "title": "Map Conditions",
      "description": "Active environmental conditions (toxic fallout, etc.).",
      "gridPos": { "x": 13, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 1 },
              { "color": "#e898a8", "value": 3 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(rimworld_map_condition_active) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 309,
      "type": "stat",
      "title": "Research Completed",
      "description": "Total research projects completed.",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#8ec4a8" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#8ec4a8", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_research_completed_total",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 310,
      "type": "stat",
      "title": "Settlements",
      "description": "Total colony settlements on the world map.",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#8486d4" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#8486d4", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colony_settlements_total",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 311,
      "type": "row",
      "title": "Threat Budget",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 312,
      "type": "timeseries",
      "title": "Threat Points Full History",
      "description": "Climbs with wealth, dips after each raid. Annotations show raid and death events.",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "#e898a8" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 300 },
              { "color": "#e898a8", "value": 800 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_storyteller_threat_points",
          "legendFormat": "Threat Budget",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 313,
      "type": "row",
      "title": "Combat State",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 314,
      "type": "timeseries",
      "title": "Hostile Pawns & Combat State",
      "description": "Hostile count alongside downed, mental breaks, and drafted colonists.",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hostile Pawns" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Downed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#d4b896" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Mental Breaks" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f08030" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Drafted" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#82b8c8" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_hostile_pawns_on_map",
          "legendFormat": "Hostile Pawns",
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_downed_total",
          "legendFormat": "Downed",
          "instant": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_mental_state_active",
          "legendFormat": "Mental Breaks",
          "instant": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_drafted_total",
          "legendFormat": "Drafted",
          "instant": false,
          "refId": "D"
        }
      ]
    },

    {
      "id": 315,
      "type": "timeseries",
      "title": "Combat State Composition",
      "description": "Stacked area showing colonist combat states over time. 0 = peacetime.",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Downed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#d4b896" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Mental Breaks" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Drafted" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#82b8c8" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_downed_total",
          "legendFormat": "Downed",
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_mental_state_active",
          "legendFormat": "Mental Breaks",
          "instant": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_drafted_total",
          "legendFormat": "Drafted",
          "instant": false,
          "refId": "C"
        }
      ]
    },

    {
      "id": 316,
      "type": "row",
      "title": "Faction Relations",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 317,
      "type": "timeseries",
      "title": "Faction Goodwill",
      "description": "Goodwill with all known factions. Below 0 = hostile territory. Sudden drops may precede raids.",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short",
          "min": -100,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_faction_goodwill",
          "legendFormat": "{{faction_name}} ({{faction_type}})",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 318,
      "type": "row",
      "title": "Active Threats",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 319,
      "type": "table",
      "title": "Active Map Conditions",
      "description": "Environmental conditions currently active on the map.",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "displayName": "condition_label", "desc": false }]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {

{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "enable": true,
        "expr": "{service_name=\"rimworld-colony\"} | json | event_type=~\"incident|death\"",
        "hide": false,
        "iconColor": "#e898a8",
        "name": "Raids & Deaths",
        "step": "60s",
        "titleFormat": "{{body}}",
        "tagKeys": "event_type"
      },
      {
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "enable": true,
        "expr": "{service_name=\"rimworld-colony\"} | json | event_type=\"mental_break\"",
        "hide": false,
        "iconColor": "#d4b896",
        "name": "Mental Breaks",
        "step": "60s",
        "titleFormat": "{{body}}",
        "tagKeys": "event_type"
      }
    ]
  },
  "description": "RimWorld per-colonist profile drilldown. Select a colonist to inspect their full history.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Colony Command Center",
      "tooltip": "Back to main dashboard",
      "type": "link",
      "url": "/d/rimworld-colony-v2"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["rimworld", "gaming", "homelab", "colonist"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RimWorld — Colonist Profile",
  "uid": "rimworld-colonist",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "pluginId": "prometheus",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "DS_LOKI",
        "label": "Loki",
        "type": "datasource",
        "pluginId": "loki",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "colonist",
        "label": "Colonist",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(rimworld_colonist_mood, name)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [

    {
      "id": 101,
      "type": "row",
      "title": "Colonist: $colonist",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 102,
      "type": "stat",
      "title": "Current Mood",
      "description": "Current mood level (0–1).",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#e898a8", "value": null },
              { "color": "#d4b896", "value": 0.35 },
              { "color": "#8ec4a8", "value": 0.55 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_mood{name=\"$colonist\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 103,
      "type": "stat",
      "title": "Health",
      "description": "Overall health (0–1).",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#e898a8", "value": null },
              { "color": "#d4b896", "value": 0.5 },
              { "color": "#8ec4a8", "value": 0.8 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_health{name=\"$colonist\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 104,
      "type": "stat",
      "title": "Pain",
      "description": "Current pain level. Higher = worse.",
      "gridPos": { "x": 6, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 0.2 },
              { "color": "#e898a8", "value": 0.5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_pain{name=\"$colonist\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 105,
      "type": "stat",
      "title": "Age",
      "description": "Biological age in years.",
      "gridPos": { "x": 8, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#8486d4" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#8486d4", "value": null }] },
          "mappings": [],
          "displayName": "years"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_age_years{name=\"$colonist\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 106,
      "type": "stat",
      "title": "Negative Thoughts",
      "description": "Active negative thought count. Rising = watch for mental break.",
      "gridPos": { "x": 10, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 5 },
              { "color": "#e898a8", "value": 10 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_thoughts_negative_total{name=\"$colonist\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 107,
      "type": "stat",
      "title": "Total Conditions",
      "description": "Sum of all health conditions (injuries, diseases, addictions, implants, chronic).",
      "gridPos": { "x": 12, "y": 1, "w": 2, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 3 },
              { "color": "#e898a8", "value": 7 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rimworld_colonist_hediff_count{name=\"$colonist\"})",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 108,
      "type": "row",
      "title": "History",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 109,
      "type": "timeseries",
      "title": "Mood over Time",
      "description": "Mood history with break threshold overlays.",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#8486d4" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "minor break" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d4b896" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "major break" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "extreme break" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#eeb0bc" } },
              { "id": "custom.lineStyle", "value": { "dash": [2, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_mood{name=\"$colonist\"}",
          "legendFormat": "$colonist mood",
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(rimworld_colonist_mood_break_threshold_minor)",
          "legendFormat": "minor break",
          "instant": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(rimworld_colonist_mood_break_threshold_major)",
          "legendFormat": "major break",
          "instant": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(rimworld_colonist_mood_break_threshold_extreme)",
          "legendFormat": "extreme break",
          "instant": false,
          "refId": "D"
        }
      ]
    },

    {
      "id": 110,
      "type": "timeseries",
      "title": "Health & Pain History",
      "description": "Health and pain levels over time.",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#8ec4a8" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pain" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } },
              { "id": "custom.fillOpacity", "value": 5 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_health{name=\"$colonist\"}",
          "legendFormat": "Health",
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_pain{name=\"$colonist\"}",
          "legendFormat": "Pain",
          "instant": false,
          "refId": "B"
        }
      ]
    },

    {
      "id": 111,
      "type": "row",
      "title": "Needs & State",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 112,
      "type": "timeseries",
      "title": "All Needs",
      "description": "All colonist needs over time (food, rest, recreation, etc.).",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_need{name=\"$colonist\"}",
          "legendFormat": "{{need}}",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 113,
      "type": "timeseries",
      "title": "Negative Thoughts History",
      "description": "Count of active negative thoughts. Threshold lines at 5 and 10.",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "#e898a8" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#8ec4a8", "value": null },
              { "color": "#d4b896", "value": 5 },
              { "color": "#e898a8", "value": 10 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_thoughts_negative_total{name=\"$colonist\"}",
          "legendFormat": "Negative Thoughts",
          "instant": false,
          "refId": "A"
        }
      ]
    },

    {
      "id": 114,
      "type": "row",
      "title": "Skills & Conditions",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 115,
      "type": "bargauge",
      "title": "Skills",
      "description": "Current skill levels (0–20). Color indicates passion level.",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 20,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6b6f9e", "value": null },
              { "color": "#d4b896", "value": 8 },
              { "color": "#e898a8", "value": 14 }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*passion=\"0\".*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#6b6f9e" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*passion=\"1\".*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d4b896" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*passion=\"2\".*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rimworld_colonist_skill{name=\"$colonist\"}",
          "legendFormat": "{{skill}} (passion {{passion}})",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 116,
      "type": "timeseries",
      "title": "Health Conditions by Category",
      "description": "Injury, Disease, Addiction, Implant, Chronic counts over time.",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 40,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Injury" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e898a8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Disease" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#d4b896" } }]
          },
          {
